# ===========================================================
# DRISHTI Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================================

# --- Application ---
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
APP_DEBUG=true
APP_VERSION=1.0.0

# --- Database ---
DATABASE_URL=postgresql://drishti_user:drishti_pass@localhost:5432/drishti_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis (cache & message broker) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-jwt-secret-key-must-be-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AWS S3 (evidence storage) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=drishti-evidence-store
S3_ENCRYPTION=AES256

# --- Twilio (WhatsApp + SMS alerts) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# --- Google Maps API ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Face Recognition ---
FACE_RECOGNITION_MODEL=ArcFace
FACE_RECOGNITION_THRESHOLD=0.6
FACE_DB_PATH=/data/face_embeddings

# --- ML Model Paths ---
ML_MODELS_DIR=/app/ml/models
GAIT_MODEL_PATH=/app/ml/models/opengait.pth
AGE_PROGRESSION_MODEL_PATH=/app/ml/models/sam_age.pth
CLIP_MODEL_NAME=ViT-B/32

# --- Celery (async task queue) ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@drishti.gov.in
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=DRISHTI Alert System

# --- Encryption ---
ENCRYPTION_KEY=base64-encoded-32-byte-key-here

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://drishti.gov.in

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/drishti/app.log

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=100

# --- Audit ---
AUDIT_LOG_RETENTION_DAYS=365
